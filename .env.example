# MiMo API credentials — get yours at https://platform.xiaomimimo.com
MIMO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) override the base URL if you are proxying
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Port to bind on the host. Inside the container we always listen on 8080.
HOST_PORT=8080
