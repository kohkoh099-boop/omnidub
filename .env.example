# MiMo API credentials — get yours at https://platform.xiaomimimo.com
MIMO_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token Plan (Singapore region) endpoint. Use api.xiaomimimo.com/v1 for the
# regular pay-as-you-go account.
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Port to bind on the host. Inside the container we always listen on 8080.
HOST_PORT=8080
